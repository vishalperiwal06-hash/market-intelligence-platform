# ─────────────────────────────────────────────────────────────
# AI Bazaar — Environment Configuration
# Copy to .env and fill in values
# ─────────────────────────────────────────────────────────────

# ── Core Database ────────────────────────────────────────────
DATABASE_URL=postgresql://aibazaar:changeme_in_production@db:5432/aibazaar
POSTGRES_DB=aibazaar
POSTGRES_USER=aibazaar
POSTGRES_PASSWORD=changeme_in_production

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Authentication ───────────────────────────────────────────
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ── Local AI (Ollama) ────────────────────────────────────────
# Default: http://localhost:11434 (or http://ollama:11434 in Docker)
OLLAMA_BASE_URL=http://localhost:11434

# ── Cloud AI Providers (ALL OPTIONAL — local-first architecture) ──
# Leave empty to run in fully local mode using Ollama.
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Application ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000
